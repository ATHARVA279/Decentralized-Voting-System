{
  "compilerOptions": {
    "outDir":              "./out-tsc/spec",
    "baseUrl":             "./",
    "types":               ["jasmine"],
    "target":              "ES2022",
    "module":              "ES2022",
    "lib":                 ["ES2022", "dom"],
    "strict":              true,
    "moduleResolution":    "bundler",
    "experimentalDecorators": true
  },
  "include":  ["src/**/*.spec.ts", "src/**/*.d.ts"]
}
