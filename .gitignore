# ── Rust ──────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock          # Keep this for binaries (remove for library crates)
*.pdb

# ── Node / Angular ────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.angular/
frontend/.cache/
npm-debug.log*
yarn-error.log

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
kubeconfig
kubeconfig.*
**/secrets/*.yaml        # K8s secrets should never be committed
!k8s/secrets/.gitkeep   # Keep the folder structure

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test artifacts ────────────────────────────────────────────────────────────
coverage/
test-results/

# ── Terraform ────────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars
*.tfvars
